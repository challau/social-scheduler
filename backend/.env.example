# -----------------------------------------------------------------------------
# SocialFlow AI - Backend Environment Variables Template
# Copy this file to .env and fill in real values.
# Do NOT check .env files into version control.
# -----------------------------------------------------------------------------

# 1. CORE API & SECURITY
# JWT signing key AND encryption key for stored social tokens (Fernet key is
# derived from it). Generate with: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# 2. PUBLIC URLS
# Public URL of the deployed backend (Render/Railway). OAuth redirect URIs
# ({BACKEND_URL}/oauth/{platform}/callback) and locally stored media URLs
# are derived from this.
BACKEND_URL=https://your-backend.onrender.com
# Public URL of the deployed frontend (Vercel). Used for post-OAuth browser
# redirects and automatically added to CORS allowed origins.
FRONTEND_URL=https://your-app.vercel.app

# Extra CORS origins (comma-separated). FRONTEND_URL is always allowed.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Set true behind a proxy that terminates TLS (Render/Railway) to force HTTPS
FORCE_HTTPS=true

# 3. DATABASE (PostgreSQL in production; falls back to SQLite if unset)
# Render/Railway/Neon provide this. postgres:// URLs are normalized automatically.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# 4. REDIS (PKCE verifiers, caching; falls back to in-memory if unreachable)
REDIS_URL=redis://localhost:6379/0

# 5. SCHEDULER
# false in production web service (a dedicated worker runs
# `python -m app.workers.run_worker`); true for local single-process dev
RUN_SCHEDULER_IN_WEB=true

# 6. TELEMETRY (leave empty to disable)
SENTRY_DSN=

# 7. STRIPE BILLING
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=price_pro_subscription_monthly

# 8. OPENAI (AI caption generation; mock captions are used if empty)
OPENAI_API_KEY=

# 9. CLOUDINARY MEDIA STORAGE (recommended in production — local disk on
# Render/Railway is ephemeral). Either the consolidated URL or explicit keys.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 10. SOCIAL OAUTH CREDENTIALS
# Redirect URIs default to {BACKEND_URL}/oauth/{platform}/callback — only set
# the *_REDIRECT_URI overrides if a provider requires a different path.
# Register the same URIs in each developer portal.
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
#INSTAGRAM_REDIRECT_URI=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
#LINKEDIN_REDIRECT_URI=

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
#TWITTER_REDIRECT_URI=

# 11. SMTP EMAIL NOTIFICATIONS (logged to console if credentials empty)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=notifications@socialflow.ai

# 12. MOCK MODE (forces mock social APIs; set false in production)
MOCK_MODE=false
